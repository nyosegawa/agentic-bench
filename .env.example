# .env.example — required API keys for agentic-bench
HF_TOKEN=             # HuggingFace Pro token (required)
BEAM_TOKEN=           # beam.cloud API token (beam.cloud usage)
MODAL_TOKEN_ID=       # Modal token ID (Modal usage)
MODAL_TOKEN_SECRET=   # Modal token secret (Modal usage)
OPENAI_API_KEY=       # OpenAI API key (API model verification)
ANTHROPIC_API_KEY=    # Anthropic API key (API model verification)
GOOGLE_API_KEY=       # Google AI API key (API model verification)
